<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My External Brain</title>
    <style>
        :root {
            --bg-color: #fefcf7; /* Warm cottagecore parchment */
            --card-bg: #ffffff;
            --text-main: #252b2e; 
            --text-muted: #5a656b;
            --accent-forest: #123c24; 
            --border: #ede8e0; 

            /* Bright, Vivid Jewel Tones mapped exactly to your 7 buckets */
            --jt-home-improvement: #d11a2a;      /* Radiant Ruby */
            --jt-home-maintenance: #0066cc;    /* Vivid Sapphire */
            --jt-health: #00a86b;              /* Glowing Emerald */
            --jt-working-out: #ff7f00;         /* Bright Amber */
            --jt-crafts: #9932cc;              /* Electric Amethyst */
            --jt-continuing-learning: #00ced1;  /* Bright Topaz */
            --jt-work: #e60073;                /* Vibrant Tourmaline Pink */
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            /* Swapped out Apple Chancery for Palatino/Georgia for a smooth, elegant ink feel */
            font-family: "Palatino", "Palatino Linotype", "Georgia", serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            padding: 20px;
            display: flex;
            justify-content: center;
        }

        .container {
            width: 100%;
            max-width: 600px;
        }

        header {
            margin-bottom: 20px;
            text-align: center;
            border-bottom: 2px dashed var(--border);
            padding-bottom: 15px;
        }

        h1 {
            font-size: 2rem;
            color: var(--accent-forest);
            font-style: italic;
            font-weight: bold;
            letter-spacing: 0.02em;
        }

        .input-section {
            background: var(--card-bg);
            padding: 15px;
            border-radius: 14px;
            border: 1px solid var(--border);
            box-shadow: 0 4px 15px rgba(43, 39, 31, 0.04);
            margin-bottom: 25px;
        }

        textarea {
            width: 100%;
            height: 45px; 
            padding: 10px 12px;
            border: 1px solid var(--border);
            border-radius: 8px;
            resize: none;
            font-size: 1.05rem; 
            margin-bottom: 10px;
            background-color: #fffdfa;
        }

        textarea:focus {
            outline: none;
            border-color: var(--accent-forest);
            background-color: #fff;
        }

        button {
            width: 100%;
            background-color: var(--accent-forest);
            color: #fefcf7;
            border: none;
            padding: 12px;
            border-radius: 8px;
            font-size: 1.1rem;
            font-weight: bold;
            cursor: pointer;
            transition: opacity 0.2s;
        }

        button:disabled {
            background-color: var(--text-muted);
            cursor: not-allowed;
        }

        .task-list {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .task-card {
            background: var(--card-bg);
            padding: 18px;
            border-radius: 12px;
            border: 1px solid var(--border);
            border-top-width: 6px; 
            box-shadow: 0 4px 6px rgba(0,0,0,0.01);
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
        }

        .bucket-tag {
            font-size: 0.8rem;
            font-weight: bold;
            letter-spacing: 0.05em;
            padding: 4px 10px;
            border-radius: 6px;
            color: #fff !important;
            font-family: sans-serif; /* Keep tags clean and scannable */
        }

        .urgency-score {
            font-size: 0.9rem;
            font-style: italic;
            color: var(--text-muted);
        }

        .main-task-title {
            font-size: 1.3rem;
            font-weight: bold;
            font-style: italic; 
            margin-bottom: 12px;
            color: #111;
        }

        .progress-container {
            background: #f0ede6;
            height: 6px;
            border-radius: 3px;
            margin-bottom: 15px;
            overflow: hidden;
        }

        .progress-bar {
            height: 100%;
            width: 0%; 
            transition: width 0.3s;
        }

        .steps-container {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .step-item {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            font-size: 1.1rem;
        }

        .step-item input[type="checkbox"] {
            margin-top: 5px;
            width: 16px;
            height: 16px;
            cursor: pointer;
        }

        footer {
            margin-top: 50px;
            text-align: center;
            border-top: 1px dashed var(--border);
            padding-top: 25px;
        }
        
        .api-input {
            padding: 8px;
            font-size: 0.9rem;
            border: 1px solid var(--border);
            border-radius: 6px;
            width: 180px;
            background: #fffdfa;
        }
    </style>
</head>
<body>

<div class="container">
    <header>
        <h1>My External Brain</h1>
    </header>

    <div class="input-section">
        <textarea id="rawThought" placeholder="Type your messy thoughts here..."></textarea>
        <button id="actionBtn" onclick="processInput()">Decompress Thoughts</button>
    </div>

    <div class="task-list" id="taskList"></div>

    <footer>
        <input type="password" id="apiKeyInput" class="api-input" placeholder="Gemini API Key">
        <button onclick="saveApiKey()" style="width: auto; padding: 6px 12px; font-size: 0.8rem; background-color: var(--text-muted); color: white;">Save Key</button>
    </footer>
</div>

<script>
    // Initialize task storage and bucket history
let tasks = JSON.parse(localStorage.getItem('my_ai_tasks')) || [];
let bucketHistory = JSON.parse(localStorage.getItem('my_bucket_history')) || {
    "Home improvement": Date.now(),
    "Home maintenance": Date.now(),
    "Health": Date.now(),
    "Working out": Date.now(),
    "Crafts": Date.now(),
    "Continuing learning": Date.now(),
    "Work": Date.now()
};

window.onload = function() {
    renderTasks();
    if(localStorage.getItem('gemini_api_key')) {
        document.getElementById('apiKeyInput').value = "••••••••••••";
    }
};

function saveApiKey() {
    const key = document.getElementById('apiKeyInput').value;
    if(key && key !== "••••••••••••") {
        localStorage.setItem('gemini_api_key', key);
        alert('API Key saved locally!');
    }
}

function renderTasks() {
    const container = document.getElementById('taskList');
    container.innerHTML = '';

    if(tasks.length === 0) {
        container.innerHTML = `<p style="text-align:center; font-style:italic; color:var(--text-muted); margin-top:20px;">Your mind is clear. Nothing currently on the radar.</p>`;
        return;
    }

    // --- THE DYNAMIC DECAY SORT ENGINE ---
    const now = Date.now();
    const msInDay = 24 * 60 * 60 * 1000;

    tasks.forEach(task => {
        // Calculate days since the entire bucket was last touched
        const lastBucketTouch = bucketHistory[task.bucket] || now;
        const daysBucketNeglected = (now - lastBucketTouch) / msInDay;

        // Calculate days since this specific item was created
        const daysItemNeglected = (now - (task.created || now)) / msInDay;

        // Compute the master urgency score
        task.urgencyScore = (daysBucketNeglected * 1.5) + (daysItemNeglected * 0.5);
    });

    // Sort tasks globally: Highest Urgency Score floats to the top
    tasks.sort((a, b) => b.urgencyScore - a.urgencyScore);
    // -------------------------------------

    tasks.forEach((task, taskIndex) => {
        const cssBucketName = task.bucket.toLowerCase().replace(/ /g, '-');
        const colorKey = `var(--jt-${cssBucketName})`;
        
        const totalSteps = task.steps.length;
        const completedSteps = task.steps.filter(s => s.done).length;
        const progressPercent = totalSteps > 0 ? (completedSteps / totalSteps) * 100 : 0;

        if (completedSteps === totalSteps && totalSteps > 0) {
            setTimeout(() => {
                tasks.splice(taskIndex, 1);
                saveToStorage();
                renderTasks();
            }, 400);
            return;
        }

        const card = document.createElement('div');
        card.className = 'task-card';
        card.style.borderTopColor = colorKey;

        let stepsHtml = '';
        task.steps.forEach((step, stepIndex) => {
            if (!step.done) {
                stepsHtml += `
                    <div class="step-item">
                        <input type="checkbox" style="accent-color: ${colorKey};" onclick="toggleStep(${taskIndex}, ${stepIndex}, '${task.bucket}')">
                        <span>${step.text}</span>
                    </div>
                `;
            }
        });

        // Display how many days ago it was tracked for context
        const daysAgo = Math.floor((now - (task.created || now)) / msInDay);
        const dateString = daysAgo === 0 ? "Tracked today" : `Tracked ${daysAgo}d ago`;

        card.innerHTML = `
            <div class="card-header">
                <span class="bucket-tag" style="background: ${colorKey};">${task.bucket}</span>
                <span class="urgency-score">${dateString}</span>
            </div>
            <div class="main-task-title">${task.main_task}</div>
            <div class="progress-container">
                <div class="progress-bar" style="width: ${progressPercent}%; background: ${colorKey};"></div>
            </div>
            <div class="steps-container">
                ${stepsHtml}
            </div>
        `;
        container.appendChild(card);
    });
}

function toggleStep(taskIndex, stepIndex, bucketName) {
    tasks[taskIndex].steps[stepIndex].done = true;
    
    // Update bucket history: checking a box counts as active engagement!
    bucketHistory[bucketName] = Date.now();
    
    saveToStorage();
    renderTasks(); 
}

function saveToStorage() {
    localStorage.setItem('my_ai_tasks', JSON.stringify(tasks));
    localStorage.setItem('my_bucket_history', JSON.stringify(bucketHistory));
}

async function processInput() {
    const textInput = document.getElementById('rawThought');
    const actionBtn = document.getElementById('actionBtn');
    const rawThought = textInput.value.trim();
    
    if(!rawThought) return;

    const apiKey = localStorage.getItem('gemini_api_key');
    if (!apiKey) return alert("Please enter and save your Gemini API key at the bottom first!");

    actionBtn.disabled = true;
    actionBtn.innerText = "Decompressing...";

    const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=${apiKey}`;

    try {
        const response = await fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                contents: [{ parts: [{ text: `Analyze this thought and categorize it cleanly: "${rawThought}"` }] }],
                generationConfig: {
                    responseMimeType: "application/json",
                    responseSchema: {
                        type: "OBJECT",
                        properties: {
                            bucket: { 
                                type: "STRING", 
                                enum: ["Home improvement", "Home maintenance", "Health", "Working out", "Crafts", "Continuing learning", "Work"] 
                            },
                            main_task: { type: "STRING" },
                            steps: {
                                type: "ARRAY",
                                items: {
                                    type: "OBJECT",
                                    properties: {
                                        text: { type: "STRING" },
                                        done: { type: "BOOLEAN" }
                                    },
                                    required: ["text", "done"]
                                }
                            }
                        },
                        required: ["bucket", "main_task", "steps"]
                    }
                }
            })
        });

        const data = await response.json();
        const aiOutput = JSON.parse(data.candidates[0].content.parts[0].text);
        
        // STAMP THE TASK WITH CURRENT TIME
        aiOutput.created = Date.now();
        
        // Update bucket history because you just added something to it
        bucketHistory[aiOutput.bucket] = Date.now();

        tasks.push(aiOutput);
        saveToStorage();
        renderTasks();
        
        textInput.value = '';

    } catch (error) {
        console.error("API Error:", error);
        alert("Something went wrong processing that thought.");
    } finally {
        actionBtn.disabled = false;
        actionBtn.innerText = "Decompress Thoughts";
    }
}
</script>

</body>
</html>
